OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-pro

# Demo 3 retrieval models use DashScope only. Repo .env overrides inherited environment variables.
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_API_KEY=
DEMO3_EMBEDDING_MODEL=text-embedding-v3
DEMO3_RERANK_MODEL=qwen3-vl-rerank

# Demo 2 defaults:
# Planner temperature: 0.7
# Executor temperature: 0.3

# Demo 4 arXiv MCP server. Defaults run `uvx arxiv-mcp-server` over stdio.
DEMO4_MCP_COMMAND=uvx
DEMO4_MCP_ARGS=arxiv-mcp-server
DEMO4_ARXIV_STORAGE_PATH=demo4_blackboard/data/arxiv
DEMO4_UV_CACHE_DIR=demo4_blackboard/data/uv-cache
DEMO4_UV_TOOL_DIR=demo4_blackboard/data/uv-tools
DEMO4_MCP_TIMEOUT_SECONDS=300
DEMO4_ENABLE_VIEWER_LOGS=0
